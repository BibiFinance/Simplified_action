// SimplifiedAction - Schéma BDD pour dbdiagram.io
// Coller ce contenu sur https://dbdiagram.io pour visualiser le schéma

Project SimplifiedAction {
  database_type: 'PostgreSQL'
  Note: 'Base de données du projet SimplifiedAction - BTS SIO SLAM'
}

Table users {
  id int [pk, increment, note: 'Identifiant unique']
  email varchar(255) [unique, not null, note: 'Email de connexion']
  password_hash varchar(255) [not null, note: 'Hash Argon2']
  stripe_customer_id varchar(255) [unique, note: 'ID client Stripe']
  created_at timestamp [default: `now()`, note: 'Date d\'inscription']
  
  Note: 'Utilisateurs inscrits'
}

Table stripe_subscriptions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  stripe_subscription_id varchar(255) [unique, not null]
  stripe_price_id varchar(255)
  status varchar(50) [note: 'active, canceled, past_due']
  current_period_end timestamp
  created_at timestamp [default: `now()`]
  
  Note: 'Abonnements gérés via Stripe'
}

Table actions {
  id int [pk, increment]
  ticker varchar(20) [unique, not null, note: 'Symbole boursier']
  entreprise varchar(255) [not null]
  secteur varchar(120)
  rendement float
  risque float
  
  Note: 'Actions récupérées via API finance'
}

Table notations {
  id int [pk, increment]
  action_id int [ref: > actions.id]
  note_globale float [note: 'Score 0-10']
  version_algo varchar(20)
  date_calcul timestamp [default: `now()`]
  
  Note: 'Scores calculés (historique)'
}

Table favoris {
  id int [pk, increment]
  user_id int [ref: > users.id]
  action_id int [ref: > actions.id]
  created_at timestamp [default: `now()`]
  
  indexes {
    (user_id, action_id) [unique]
  }
  Note: 'Watchlist utilisateur'
}

Table flux_news {
  id int [pk, increment]
  titre varchar(500)
  source varchar(255)
  url varchar(500) [unique]
  resume text
  date_publi timestamp
  action_id int [ref: > actions.id]
  
  Note: 'Actualités via flux RSS'
}

// Table optionnelle (créée par le code si BDD utilisée)
Table sp500_companies {
  symbol varchar(20) [pk, note: 'Ticker S&P 500']
  name varchar(255) [not null]
  sector varchar(120)
  industry varchar(120)
  is_pro boolean [default: false]
  updated_at timestamp [default: `now()`]
  
  Note: 'Liste statique S&P 500 (ou chargée en BDD)'
}
