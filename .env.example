# Simplifiedaction – variables d'environnement (copier en .env)

PORT=3000
JWT_SECRET=changez-moi-en-production

# PostgreSQL (comptes, favoris, historique notations, abonnements Stripe)
DATABASE_URL=postgresql://postgres:mot_de_passe@localhost:5432/simplifiedaction

# Finnhub – cours et scores temps réel (https://finnhub.io)
# Sans clé : mode dégradé (données simulées)
FINNHUB_API_KEY=

# Stripe – abonnements Premium (mode test : clés sk_test_ / pk_test_)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
# Webhook (prod ou stripe listen en local) ; verify-session suffit en dev
STRIPE_WEBHOOK_SECRET=
